{
  "manifest_version": 3,
  "name": "Font Reader",
  "version": "1.0.0",
  "description": "Scan and identify fonts used on any webpage",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.ts"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background/background.ts",
    "type": "module"
  }
}
